# Streamlit Secrets Template
# ─────────────────────────────────────────────────────────────
# DO NOT commit this file. Copy it to .streamlit/secrets.toml
# and fill in your values.
#
# On Streamlit Community Cloud:
#   App → ⋮ menu → Settings → Secrets → paste the content below
# ─────────────────────────────────────────────────────────────

GEMINI_API_KEY = "your-gemini-api-key-from-aistudio.google.com"

GMAIL_APP_PASSWORD = "your-16-char-gmail-app-password"

# GitHub Personal Access Token (needs: repo + workflow scopes)
GH_PAT = "ghp_your_personal_access_token"

# Format: "yourgithubusername/opportunitybot"
GITHUB_REPO = "yourusername/opportunitybot"
